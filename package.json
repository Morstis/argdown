{
  "name": "argdown-monorepo",
  "author": "Christian Voigt <1pxsolidblack@googlemail.com>",
  "repository": "https://github.com/argdown/argdown",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "workspace-sources": {
    "*": [
      "packages/*/src"
    ]
  },
  "scripts": {
    "build": "lerna run build",
    "test": "lerna run test",
    "docs:dev": "yarn workspace @argdown/docs run docs:dev",
    "prettier:check": "lerna run prettier:check && prettier . --check",
    "prettier:fix": "prettier . --write",
    "prettier": "yarn run prettier:fix",
    "lint": "eslint",
    "lint:all": "eslint packages/argdown-cli/src packages/argdown-core/src packages/argdown-image-export/src packages/argdown-language-server/src packages/argdown-map-views/src packages/argdown-markdown-it-plugin/src packages/argdown-marked-plugin/src packages/argdown-node/src packages/argdown-vscode/src packages/argdown-web-components/src && yarn workspaces foreach -A --include @argdown/sandbox run lint"
  },
  "readmeFilename": "Readme.md",
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.15.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.15.0",
    "lerna": "^9.0.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.18.0"
  },
  "packageManager": "yarn@4.9.4",
  "engines": {
    "node": ">= 20.0.0"
  }
}
