{
  "name": "argdown-vscode",
  "displayName": "Argdown",
  "description": "Live preview and full language support for the Argdown argumentation syntax",
  "icon": "media/argdown-mark-blue-256x256.png",
  "author": "Christian Voigt",
  "license": "MIT",
  "version": "2.0.0",
  "publisher": "argdown",
  "homepage": "https://argdown.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/argdown/argdown"
  },
  "bugs": {
    "url": "https://github.com/argdown/argdown/issues"
  },
  "engines": {
    "vscode": "^1.99.0",
    "node": ">= 22.11.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "multi-root ready",
    "argumentation",
    "argument mapping",
    "Markdown"
  ],
  "activationEvents": [
    "onView:argdown.preview",
    "onWebviewPanel:argdown.preview",
    "workspaceContains:**/*.{argdown,ad,argdn,adown}"
  ],
  "main": "./dist/main.node.js",
  "browser": "./dist/main.browser.js",
  "contributes": {
    "languages": [
      {
        "id": "argdown",
        "aliases": [
          "Argdown",
          "argdown"
        ],
        "extensions": [
          ".ad",
          ".adown",
          ".argdown",
          ".argdn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "argdown",
        "scopeName": "text.html.argdown",
        "path": "./syntaxes/argdown.tmLanguage.json"
      },
      {
        "scopeName": "markdown.argdown.codeblock",
        "path": "./syntaxes/inject-argdown-into-markdown.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.argdown": "argdown"
        }
      }
    ],
    "themes": [
      {
        "label": "Argdown Light (default light + Argdown token highlighting)",
        "uiTheme": "vs",
        "path": "./themes/argdown-light.json"
      },
      {
        "label": "Argdown Dark (default dark + Argdown token highlighting)",
        "uiTheme": "vs-dark",
        "path": "./themes/argdown-dark.json"
      }
    ],
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./dist/assets/argdown-map.css",
      "./media/argdown-map.vscode.css"
    ],
    "markdown.previewScripts": [
      "./dist/assets/argdown-map.umd.cjs"
    ],
    "jsonValidation": [
      {
        "fileMatch": "argdown.config.json",
        "url": "./syntaxes/argdown-config.schema.json"
      }
    ],
    "commands": [
      {
        "command": "argdown.exportDocumentToHtml",
        "title": "Export to HTML",
        "category": "Argdown"
      },
      {
        "command": "argdown.exportDocumentToJson",
        "title": "Export data to JSON",
        "category": "Argdown"
      },
      {
        "command": "argdown.exportDocumentToDot",
        "title": "Export map data to DOT",
        "category": "Argdown"
      },
      {
        "command": "argdown.exportDocumentToGraphML",
        "title": "Export map data to GraphML",
        "category": "Argdown"
      },
      {
        "command": "argdown.copyWebComponentToClipboard",
        "title": "Export Viz.js map as web component and copy it to the clipboard",
        "category": "Argdown"
      },
      {
        "command": "argdown.exportDocumentToVizjsSvg",
        "title": "Export Viz.js map to SVG",
        "category": "Argdown"
      },
      {
        "command": "argdown.exportDocumentToVizjsPdf",
        "title": "Export Viz.js map to PDF",
        "category": "Argdown"
      },
      {
        "command": "argdown.exportContentToVizjsPng",
        "title": "Export Viz.js map to PNG",
        "category": "Argdown"
      },
      {
        "command": "argdown.exportContentToDagrePng",
        "title": "Export Dagre map to PNG",
        "category": "Argdown"
      },
      {
        "command": "argdown.exportContentToDagrePdf",
        "title": "Export Dagre map to PDF",
        "category": "Argdown"
      },
      {
        "command": "argdown.exportContentToDagreSvg",
        "title": "Export Dagre map to Svg",
        "category": "Argdown"
      },
      {
        "command": "argdown.showPreview",
        "title": "Open Preview",
        "category": "Argdown",
        "icon": {
          "light": "./media/icons/light/preview.svg",
          "dark": "./media/icons/dark/preview.svg"
        }
      },
      {
        "command": "argdown.showPreviewToSide",
        "title": "Open Preview to the Side",
        "category": "Argdown",
        "icon": {
          "light": "./media/icons/light/open-preview.svg",
          "dark": "./media/icons/dark/open-preview.svg"
        }
      },
      {
        "command": "argdown.showLockedPreviewToSide",
        "title": "Open locked Preview to the Side",
        "category": "Argdown",
        "icon": {
          "light": "./media/icons/light/open-preview.svg",
          "dark": "./media/icons/dark/open-preview.svg"
        }
      },
      {
        "command": "argdown.showSource",
        "title": "Show Source",
        "category": "Argdown",
        "icon": {
          "light": "./media/icons/light/go-to-file.svg",
          "dark": "./media/icons/dark/go-to-file.svg"
        }
      },
      {
        "command": "argdown.showPreviewSecuritySelector",
        "title": "Change Preview Security Settings",
        "category": "Argdown"
      },
      {
        "command": "argdown.preview.refresh",
        "title": "Refreshes the preview",
        "category": "Argdown"
      },
      {
        "command": "argdown.preview.toggleLock",
        "title": "Toggle Preview Locking",
        "category": "Argdown"
      },
      {
        "command": "argdown.run",
        "title": "Run Argdown parser with config file",
        "category": "Argdown"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "argdown.showPreviewToSide",
          "when": "editorLangId == argdown",
          "alt": "argdown.showPreview",
          "group": "navigation"
        },
        {
          "command": "argdown.showSource",
          "when": "argdownPreviewFocus",
          "group": "navigation"
        },
        {
          "command": "argdown.preview.refresh",
          "when": "argdownPreviewFocus",
          "group": "1_argdown"
        },
        {
          "command": "argdown.preview.toggleLock",
          "when": "argdownPreviewFocus",
          "group": "1_argdown"
        },
        {
          "command": "argdown.showPreviewSecuritySelector",
          "when": "argdownPreviewFocus",
          "group": "1_argdown"
        }
      ],
      "explorer/context": [
        {
          "command": "argdown.showPreview",
          "when": "resourceLangId == argdown",
          "group": "navigation"
        },
        {
          "command": "argdown.exportDocumentToHtml",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToJson",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToDot",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToGraphML",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.copyWebComponentToClipboard",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToVizjsSvg",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToVizjsPdf",
          "when": "resourceLangId == argdown",
          "group": "export"
        }
      ],
      "editor/title/context": [
        {
          "command": "argdown.showPreview",
          "when": "resourceLangId == argdown",
          "group": "navigation"
        },
        {
          "command": "argdown.exportDocumentToHtml",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToJson",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToDot",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToGraphML",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.copyWebComponentToClipboard",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToVizjsSvg",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToVizjsPdf",
          "when": "resourceLangId == argdown",
          "group": "export"
        }
      ],
      "commandPalette": [
        {
          "command": "argdown.run"
        },
        {
          "command": "argdown.exportDocumentToHtml",
          "when": "editorLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToJson",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToDot",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToGraphML",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.copyWebComponentToClipboard",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToVizjsSvg",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.exportDocumentToVizjsPdf",
          "when": "resourceLangId == argdown",
          "group": "export"
        },
        {
          "command": "argdown.showPreview",
          "when": "editorLangId == argdown",
          "group": "navigation"
        },
        {
          "command": "argdown.showPreviewToSide",
          "when": "editorLangId == argdown",
          "group": "navigation"
        },
        {
          "command": "argdown.showLockedPreviewToSide",
          "when": "editorLangId == argdown",
          "group": "navigation"
        },
        {
          "command": "argdown.showSource",
          "when": "argdownPreviewFocus",
          "group": "navigation"
        },
        {
          "command": "argdown.showPreviewSecuritySelector",
          "when": "editorLangId == argdown"
        },
        {
          "command": "argdown.showPreviewSecuritySelector",
          "when": "argdownPreviewFocus"
        },
        {
          "command": "argdown.preview.toggleLock",
          "when": "argdownPreviewFocus"
        }
      ]
    },
    "keybindings": [
      {
        "command": "argdown.showPreview",
        "key": "shift+ctrl+v",
        "mac": "shift+cmd+v",
        "when": "editorLangId == argdown"
      },
      {
        "command": "argdown.showPreviewToSide",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == argdown"
      }
    ],
    "argdown.previewStyles": [
      "./media/argdown.css",
      "./media/vscode.css"
    ],
    "configuration": {
      "type": "object",
      "title": "Argdown configuration",
      "properties": {
        "argdown.configFile": {
          "scope": "resource",
          "type": "string",
          "default": "argdown.config.js",
          "description": "Path at which the parser should look for an Argdown config file."
        },
        "argdown.markdownWebComponent.enabled": {
          "scope": "resource",
          "type": "boolean",
          "default": true,
          "description": "Use Argdown markdown-it plugin in the Markdown preview to replace argdown-map code fences. (Requires reloading VSCode.)"
        },
        "argdown.markdownWebComponent.withoutHeader": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Hide the header of the argdown-map web component."
        },
        "argdown.markdownWebComponent.withoutLogo": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Hide the logo of the argdown-map web component."
        },
        "argdown.markdownWebComponent.withoutMaximize": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Hide the maximize button of the argdown-map web component."
        },
        "argdown.preview.trace": {
          "type": "string",
          "enum": [
            "off",
            "verbose"
          ],
          "default": "off",
          "description": "Log debug and error messages.",
          "scope": "window"
        },
        "argdown.preview.doubleClickToSwitchToEditor": {
          "scope": "resource",
          "type": "boolean",
          "default": true,
          "description": "Double click on element jumps to line in text editor."
        },
        "argdown.preview.syncPreviewSelectionWithEditor": {
          "scope": "resource",
          "type": "boolean",
          "default": true,
          "description": "Highlight and reveal arguments and statements in the map if their titles are selected in the editor"
        },
        "argdown.preview.lockMenu": {
          "scope": "application",
          "type": "boolean",
          "default": true,
          "description": "If false the preview menu will only be shown if the mouse moves over to the top of the preview window."
        },
        "argdown.preview.minDelayBetweenUpdates": {
          "scope": "application",
          "type": "number",
          "default": 300,
          "description": "The time in milliseconds the extension waits for further changes before updating the preview if the text or the selection has changed. Requires restart if changed."
        },
        "argdown.preview.defaultView": {
          "scope": "application",
          "type": "string",
          "default": "vizjs",
          "enum": [
            "html",
            "dagre",
            "vizjs"
          ],
          "description": "The type of preview used by default for new previews"
        }
      }
    }
  },
  "vsce": {
    "dependencies": false,
    "useYarn": true
  },
  "scripts": {
    "vscode:prepublish": "yarn run build",
    "package": "vsce package",
    "dev:node": "tsx esbuild/esbuild.node.ts --watch",
    "dev:browser": "tsx esbuild/esbuild.browser.ts --watch",
    "dev:preview": "tsx esbuild/esbuild.preview.ts --watch",
    "dev": "yarn run clean && run-p \"copy:*\" && run-p \"dev:*\" ",
    "build:node": "tsx esbuild/esbuild.node.ts --production",
    "build:browser": "tsx esbuild/esbuild.browser.ts --production",
    "build:preview": "tsx esbuild/esbuild.preview.ts --production",
    "build": "yarn run clean && run-p \"build:*\" && run-p \"copy:*\"",
    "clean": "rimraf \"dist/\"",
    "copy:web-components": "mkdir -p dist/assets/ && cp ../argdown-web-components/dist/argdown-map.* dist/assets/",
    "copy:language-server": "mkdir -p dist/server/ && cp ../argdown-language-server/dist/server.* dist/server/",
    "pretest": "tsc -p tsconfig.test.json",
    "test:browser": "vscode-test-web --extensionDevelopmentPath . --extensionTestsPath ./out/test/web/web-extension.test.js --browser chromium --headless",
    "test:node": "vscode-test",
    "test": "yarn run pretest && run-p \"test:*\"",
    "sandbox": "yarn run build && vscode-test-web --extensionDevelopmentPath . --headless"
  },
  "dependencies": {
    "@argdown/core": "workspace:^",
    "@argdown/language-server": "workspace:^",
    "@argdown/map-views": "workspace:^",
    "@argdown/markdown-it-plugin": "workspace:^",
    "@argdown/web-components": "workspace:^",
    "blob-stream": "^0.1.3",
    "d3-selection": "^3.0.0",
    "dagre-d3": "^0.6.3",
    "lodash.defaultsdeep": "^4.6.1",
    "lodash.merge": "^4.6.2",
    "lodash.throttle": "^4.1.1",
    "pdfkit": "^0.18.0",
    "svg-to-pdfkit": "^0.1.8",
    "vscode-languageclient": "9.0.1",
    "vscode-uri": "^3.0.7"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@types/blob-stream": "^0",
    "@types/d3": "7.4.3",
    "@types/dagre-d3": "0.6.6",
    "@types/events": "^3",
    "@types/lodash.defaultsdeep": "^4.6.9",
    "@types/lodash.merge": "^4.6.6",
    "@types/lodash.throttle": "^4.1.9",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.24",
    "@types/svg-to-pdfkit": "^0.1.4",
    "@types/vscode": "^1.99.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/test-web": "^0.0.78",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.19.0",
    "esbuild-raw-plugin": "^0.3.1",
    "events": "^3.3.0",
    "glob": "^11.0.1",
    "npm-run-all": "^4.1.5",
    "path-browserify": "^1.0.1",
    "process": "git+https://github.com/argdown/node-process",
    "rimraf": "^6.0.1",
    "stream-browserify": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "util": "^0.12.5"
  },
  "packageManager": "yarn@4.9.4"
}
