{
  "name": "@argdown/language-server",
  "description": "Language Server for the Argdown argumentation syntax.",
  "version": "1.8.0",
  "author": "Christian Voigt",
  "license": "MIT",
  "type": "module",
  "main": "./dist/server.node.cjs",
  "browser": "./dist/server.browser.cjs",
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">= 22.11.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/argdown/argdown/tree/master/packages/argdown-language-server"
  },
  "scripts": {
    "dev:browser": "tsx esbuild/esbuild.browser.ts --watch",
    "dev:node": "tsx esbuild/esbuild.node.ts --watch",
    "dev": "run-p \"dev:*\"",
    "build:browser": "tsx esbuild/esbuild.browser.ts --production",
    "build:node": "tsx esbuild/esbuild.node.ts --production",
    "build": "yarn run clean && run-p \"build:*\"",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@argdown/core": "workspace:^",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@types/node": "^22.15.24",
    "@types/path-browserify": "^1",
    "@vitest/expect": "^4.1.0",
    "esbuild": "^0.27.4",
    "npm-run-all": "^4.1.5",
    "path-browserify": "^1.0.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "1.0.12"
  },
  "packageManager": "yarn@4.9.4"
}
