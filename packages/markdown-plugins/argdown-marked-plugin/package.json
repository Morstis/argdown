{
  "name": "@argdown/marked-plugin",
  "version": "2.0.0",
  "description": "Turns Argdown code fences into svg argument maps",
  "type": "module",
  "main": "./dist/argdown-marked-plugin.js",
  "types": "./dist/argdown-marked-plugin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/argdown-marked-plugin.js",
      "types": "./dist/argdown-marked-plugin.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite serve test",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "test": "tsc --noEmit && mocha",
    "prepublishOnly": "npm run-script build"
  },
  "keywords": [
    "marked-plugin",
    "marked",
    "markdown",
    "argdown",
    "argument maps",
    "argumentation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/argdown/argdown/tree/master/packages/argdown-marked-plugin"
  },
  "author": {
    "name": "Christian Voigt",
    "email": "1pxsolidblack@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@argdown/web-components": "workspace:^",
    "@types/chai": "^5.2.2",
    "@types/lodash.defaultsdeep": "^4.6.9",
    "@types/marked": "^6.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.24",
    "chai": "^4.3.10",
    "mocha": "^11.1.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@argdown/core": "workspace:^",
    "lodash.defaultsdeep": "^4.6.1",
    "marked": "^15.0.7"
  },
  "browserslist": [
    "last 2 Chrome versions"
  ],
  "engines": {
    "node": ">= 20.0.0"
  },
  "packageManager": "yarn@4.9.4"
}
